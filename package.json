    "bezier-easing": "^2.1.0",
    "context-filter-polyfill": "^0.3.23",
    "cordova-plugin-fullscreen": "^1.3.0",
    "file-type": "^21.3.4",
    "gifuct-js": "^2.1.2",
    "jszip": "^3.10.1",
    "mathjs": "^14.9.1",
    "mime": "^4.1.0",
    "moment": "^2.30.1",
    "notiflix": "^3.2.8",
    "pako": "^2.1.0",
    "phaser": "^4.0.0",
    "query-string": "^9.3.1",
    "send-intent": "^7.0.0",
    "stats-js": "^1.0.1",
    "tar-stream": "^3.1.8",
    "wavesurfer.js": "^7.12.6",
    "yaml": "^2.8.3"
  },
  "resolutions": {
    "cookie": ">=0.7.0"
